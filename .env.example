# Ruella — gate (Solicitar acceso) email delivery via Resend
# Copy to .env.local for local dev, and set these in Vercel for production.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where access requests are delivered (the "house" inbox)
ACCESS_INBOX=

# From address. Must be a verified Resend domain in production.
# Leave unset to use Resend's test sender (onboarding@resend.dev).
ACCESS_FROM="Ruella <acceso@ruella.mx>"
