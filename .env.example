# Ruella — env vars. Copy to .env.local for local dev; set these in Vercel for production.
# The gate degrades gracefully in local dev if these are unset (logs, still returns ok).

# --- Gate delivery (correo a la casa) — Resend ---
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Buzón de la casa donde caen las solicitudes de acceso
ACCESS_INBOX=

# Remitente. Debe ser un dominio verificado en Resend para producción.
# Si se deja vacío, usa el sender de prueba de Resend (onboarding@resend.dev).
ACCESS_FROM="Ruella <acceso@ruella.mx>"

# --- Captación → CRM (pestaña Admisiones) — Apps Script Web App ---
# URL del Web App publicado desde el Google Sheet del CRM (la produce la sesión Cowork).
SHEETS_WEBHOOK_URL=

# --- Analítica ---
# ID del proyecto de Microsoft Clarity (clarity.microsoft.com).
# Público por diseño (NEXT_PUBLIC_): solo se inyecta tras consentimiento del visitante.
NEXT_PUBLIC_CLARITY_ID=

# --- Anti-bot del gate — Cloudflare Turnstile ---
# Site key (pública) y secret key del widget (modo managed/invisible).
# Si faltan, el gate funciona sin Turnstile (dev local no se bloquea).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Token de aplicación (magic-link a /aplicacion) ---
# Secreto para firmar/verificar el token HMAC de la encuesta. Genera uno fuerte:
#   openssl rand -base64 32
TOKEN_SECRET=
